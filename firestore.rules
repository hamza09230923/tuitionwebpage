rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isTeacher() {
      return signedIn() &&
        exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }

    function isStaff() {
      return isAdmin() || isTeacher();
    }

    function isOwnStudent(uid) {
      return signedIn() &&
        request.auth.uid == uid &&
        exists(/databases/$(database)/documents/students/$(uid));
    }

    function studentSubjects() {
      return get(/databases/$(database)/documents/students/$(request.auth.uid)).data.subjects;
    }

    function isEnrolledIn(subjectId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/students/$(request.auth.uid)) &&
        subjectId in studentSubjects();
    }

    match /admins/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    match /teachers/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    match /students/{uid} {
      allow read: if isOwnStudent(uid) || isStaff();
      allow write: if isStaff();
    }

    match /subjects/{subjectId} {
      allow read: if isStaff() || isEnrolledIn(subjectId);
      allow write: if isStaff();
    }

    match /recordings/{recordingId} {
      allow read: if isStaff() || (
        isEnrolledIn(resource.data.subjectId) &&
        (
          !('approvalStatus' in resource.data) ||
          resource.data.approvalStatus == 'approved'
        )
      );
      allow create, update, delete: if isStaff();
    }

    match /homeworks/{homeworkId} {
      allow read: if isStaff() || isEnrolledIn(resource.data.subjectId);
      allow create, update, delete: if isStaff();
    }

    match /webinarRegistrations/{registrationId} {
      allow read, write: if isAdmin();
    }

    match /submissions/{submissionId} {
      // Students can read only their own submissions
      allow read: if signedIn() && resource.data.studentId == request.auth.uid;
      // Students can create submissions for themselves only
      allow create: if signedIn() && request.resource.data.studentId == request.auth.uid;
      // Students can update their own submission (to change link)
      allow update: if signedIn() && resource.data.studentId == request.auth.uid;
      // Only staff can read all submissions
      allow read: if isStaff();
      // Only staff can update (mark as marked) and delete
      allow update: if isStaff();
      allow delete: if isStaff();
    }
  }
}
